# Source database
SOURCE_HOST=localhost
SOURCE_PORT=5432
SOURCE_DB=source_database
SOURCE_USER=postgres
SOURCE_PASSWORD=secret
SOURCE_SCHEMA=public

# Target database (direct DB mode)
TARGET_HOST=localhost
TARGET_PORT=5432
TARGET_DB=target_database
TARGET_USER=postgres
TARGET_PASSWORD=secret
TARGET_SCHEMA=public

# Target API (API mode)
API_BASE_URL=http://localhost:8000
API_VERSION=/api/v1
# Option 1 — fixed token (copy from your auth session)
API_TOKEN=
# Option 2 — login with credentials (leave API_TOKEN empty to use this)
API_LOGIN_ENDPOINT=/auth/login
API_LOGIN_EMAIL=
API_LOGIN_PASSWORD=

# Laboratory details (used by test_laboratories_creation.py)
LAB_NAME=AgroEnviroLab
LAB_CODE=AEL-001
LAB_ADDRESS=1642 rue de la Ferme
LAB_CITY=Farmington
LAB_PROVINCE=Quebec
LAB_POSTAL_CODE=G0B 1Z0
